<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin · <%= Madmin.site_name %></title>
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag "madmin/application" %>
    <style>
      body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100dvh;
        background-color: var(--background-color);
        font-family: ui-sans-serif, system-ui, sans-serif;
      }

      .auth-wrapper {
        width: 100%;
        max-width: 22rem;
        padding: 1rem;
      }

      .auth-header {
        text-align: center;
        margin-bottom: 2rem;
      }

      .auth-header h1 {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-color);
        margin: 0 0 0.25rem;
      }

      .auth-header p {
        font-size: 0.875rem;
        color: var(--light-text-color);
        margin: 0;
      }

      .auth-card {
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 0.5rem;
        padding: 1.75rem;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
      }

      .auth-card .field {
        margin-bottom: 1rem;
      }

      .auth-card .field label {
        display: block;
        margin-bottom: 0.375rem;
      }

      .auth-card .field input {
        width: 100%;
        box-sizing: border-box;
      }

      .auth-card .actions {
        margin-top: 1.25rem;
      }

      .auth-card .actions input[type="submit"] {
        width: 100%;
        border: none;
      }
    </style>
  </head>
  <body>
    <div class="auth-wrapper">
      <div class="auth-header">
        <h1><%= Madmin.site_name %></h1>
        <p>Admin portal</p>
      </div>
      <div class="auth-card">
        <% if flash[:alert] %>
          <div class="alert alert-danger" style="margin-bottom: 1rem; border-radius: 0.375rem;">
            <%= flash[:alert] %>
          </div>
        <% end %>
        <%= yield %>
      </div>
    </div>
  </body>
</html>
